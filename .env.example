# ─────────────────────────────────────────────
# tvstreamingvergleich.de — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────

# Public site URL (no trailing slash). Used for canonical, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL=https://tvstreamingvergleich.de

# AWIN publisher ID (used by NordVPN, CyberGhost, etc.)
# Get yours at https://www.awin.com/
NEXT_PUBLIC_AWIN_PUBLISHER_ID=

# Impact Radius partner ID (used by ExpressVPN)
# Get yours at https://impact.com/
NEXT_PUBLIC_IMPACT_PARTNER_ID=

# Amazon Partnernet associate tag (e.g. "yourtag-21")
# Get yours at https://partnernet.amazon.de/
NEXT_PUBLIC_AMAZON_TAG=

# Optional: analytics (kept empty by default to stay GDPR-friendly)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tvstreamingvergleich.de
